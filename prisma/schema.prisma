generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  emailVerified DateTime?
  password      String?
  name          String?
  image         String?
  createdAt     DateTime    @default(now())
  recordings    Recording[]
  accounts      Account[]
  sessions      Session[]
}

model Recording {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String      @default("Untitled Recording")
  status       String      @default("PENDING")
  audioPath    String?
  duration     Float?
  assemblyAiId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  speakers     Speaker[]
  utterances   Utterance[]
  analysis     Analysis?
}

model Speaker {
  id                String        @id @default(cuid())
  recordingId       String
  recording         Recording     @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  label             String
  totalSpeakingTime Float
  utterances        Utterance[]
  stances           TopicStance[]
}

model Utterance {
  id          String    @id @default(cuid())
  recordingId String
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  speakerId   String
  speaker     Speaker   @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  text        String
  startMs     Int
  endMs       Int
}

model Analysis {
  id          String   @id @default(cuid())
  recordingId String   @unique
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  summary     String
  depth       String   @default("medium")
  createdAt   DateTime @default(now())
  topics      Topic[]
}

model Topic {
  id          String        @id @default(cuid())
  analysisId  String
  analysis    Analysis      @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Topic?        @relation("SubTopics", fields: [parentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  children    Topic[]       @relation("SubTopics")
  title       String
  description String
  importance  Int
  stances     TopicStance[]
  factCheck   FactCheck?
}

model FactCheck {
  id        String   @id @default(cuid())
  topicId   String   @unique
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  results   String   // JSON: { stanceVerdicts: [{ speakerId, speakerLabel, claim, verdict, assessment, sources: [{ title, url, excerpt }] }] }
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TopicStance {
  id        String  @id @default(cuid())
  topicId   String
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  speakerId String
  speaker   Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  stance    String
}
